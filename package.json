{
  "name": "navijs",
  "version": "0.1.0",
  "description": "Framework-agnostic, type-safe in-app tour & onboarding library with Smart Locator.",
  "keywords": [
    "tour",
    "onboarding",
    "tutorial",
    "guide",
    "walkthrough",
    "intro",
    "spotlight"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "vite examples"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "happy-dom": "^15.7.4",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false
}
